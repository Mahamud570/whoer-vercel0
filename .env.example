# ─── Vercel KV (Redis) ──────────────────────────────────────────────────────
# Get these from: Vercel Dashboard → Storage → Create KV Database
# Then: vercel env pull .env.local

KV_REST_API_URL=your_kv_url_here
KV_REST_API_TOKEN=your_kv_token_here

# Without these set, the app runs fine but stores reports in memory only (dev mode).
# On Vercel, link the KV store in the dashboard and they are injected automatically.
