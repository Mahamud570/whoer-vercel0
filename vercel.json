{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?:www\\.)?proxyj\\.net"
        }
      ],
      "destination": "https://www.whoer.live/$1",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/score-details",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/css/(.*)",  "destination": "/css/$1" },
    { "source": "/js/(.*)",   "destination": "/js/$1" },
    { "source": "/img/(.*)",  "destination": "/img/$1" },
    { "source": "/directory", "destination": "/api/index" },
    { "source": "/(.*)",      "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/img/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
    }
  ]
}
