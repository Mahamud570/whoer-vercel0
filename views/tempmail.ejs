<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Temporary Email Generator — Free Disposable Inbox | Whoer Live</title>
    <meta name="description" content="Generate instant, disposable temporary email addresses. Receive real OTP codes, verification emails, and protect your inbox from spam.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://www.whoer.live/temp-mail">
    <link rel="icon" type="image/png" href="/img/logo.png">
    
    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Temporary Email Generator — Whoer Live">
    <meta property="og:description" content="Free disposable email address generator. Receive SMS & verification emails instantly without revealing your identity.">
    <meta property="og:url" content="https://www.whoer.live/temp-mail">
    <meta property="og:image" content="https://www.whoer.live/img/logo.png">

    <!-- Preload & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"></noscript>
    <style><%- include('../public/css/style.css') %></style>
    
    <style>
        .tm-wrap { max-width: 960px; margin: 0 auto; padding: 20px 20px 100px; }
        .tm-hero { text-align: center; padding: 32px 0 24px; }
        .tm-hero h1 { font-size: 32px; font-weight: 700; margin-bottom: 10px; }
        .tm-hero p { font-size: 15px; color: var(--muted); max-width: 560px; margin: 0 auto; line-height: 1.6; }
        
        .tm-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 24px; }
        .tm-box { display: flex; align-items: center; justify-content: space-between; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; margin-top: 14px; gap: 12px; flex-wrap: wrap; }
        .tm-address { font-family: var(--mono); font-size: 18px; font-weight: 700; color: var(--green); word-break: break-all; }
        
        .tm-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; align-items: center; }
        .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: var(--radius); font-weight: 600; cursor: pointer; text-decoration: none; border: 1px solid var(--border); background: var(--panel); color: var(--text); transition: all 0.2s; }
        .btn-sm:hover { background: var(--panel-hover); border-color: var(--border2); }
        .btn-sm.btn-green { background: var(--green); color: #000; border-color: var(--green); }
        .btn-sm.btn-green:hover { box-shadow: 0 4px 15px rgba(34,215,122,0.3); }

        .provider-select { padding: 8px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 13px; font-weight: 600; outline: none; }

        .inbox-table { width: 100%; border-collapse: collapse; margin-top: 14px; font-size: 14px; }
        .inbox-table th { text-align: left; padding: 12px; color: var(--muted); border-b: 1px solid var(--border); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
        .inbox-table td { padding: 14px 12px; border-b: 1px solid var(--border); color: var(--text); }
        .inbox-table tr:hover td { background: var(--panel-hover); cursor: pointer; }

        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 1000; justify-content: center; align-items: center; padding: 20px; }
        .modal-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-lg); max-width: 540px; width: 100%; padding: 28px; box-shadow: 0 20px 40px rgba(0,0,0,0.6); }
        .modal-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 16px; }
        .form-group { margin-bottom: 14px; text-align: left; }
        .form-group label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; font-weight: 600; }
        .form-input { width: 100%; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-family: var(--mono); font-size: 14px; box-sizing: border-box; }
        .form-input:focus { border-color: var(--blue); outline: none; }
    </style>
</head>
<body>

<!-- ─── HEADER ─────────────────────────────────────────────────────────── -->
<header>
    <div class="container header-inner">
        <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
            <img src="/img/logo.png" alt="Whoer Live" style="width:32px;height:32px;border-radius:8px;">
            <div class="logo">WHOER<span>.LIVE</span> <sub>v4</sub></div>
        </a>
        <div class="header-actions">
            <a href="/" class="btn">🛡️ IP Check</a>
            <a href="/temp-mail" class="btn btn-primary" style="background:var(--green);color:#000;border-color:var(--green);">✉️ Temp Mail</a>
            <a href="/bulk" class="btn">🔢 Bulk</a>
            <a href="/api-docs" class="btn">⚡ API</a>
            <a href="/threat-map" class="btn" style="color:var(--red);border-color:rgba(255,79,106,0.3);background:rgba(255,79,106,0.1);">🔴 Threats</a>
        </div>
    </div>
</header>

<!-- ─── MAIN CONTENT ────────────────────────────────────────────────────── -->
<div class="tm-wrap">
    
    <div class="tm-hero">
        <h1>Temporary Email Generator</h1>
        <p>Instant disposable email addresses for temporary registrations, 2FA verification, and real OTP reception across major web services.</p>
    </div>

    <!-- ACTIVE EMAIL CARD -->
    <div class="tm-card">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
            <div>
                <span style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;">Active Temporary Email</span>
                <div id="accStatus" style="font-size:12px;color:var(--green);margin-top:2px;">Status: Real OTP Receiver Active</div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
                <label style="font-size:12px;color:var(--muted);font-weight:600;">Engine:</label>
                <select id="engineSelect" onchange="switchEngine()" class="provider-select">
                    <option value="guerrilla" selected>GuerrillaMail (High OTP Acceptance)</option>
                    <option value="mailtm">Mail.tm (Custom Accounts & Tokens)</option>
                </select>
            </div>
        </div>

        <div class="tm-box">
            <div id="tempEmailVal" class="tm-address">Generating active temp address...</div>
            <button onclick="copyAddress()" class="btn-sm btn-green" id="copyBtn">📋 Copy Address</button>
        </div>

        <div class="tm-actions">
            <button onclick="generateNewMail()" class="btn-sm">↻ Generate New Email</button>
            <button onclick="fetchMessages()" class="btn-sm">🔄 Check Inbox</button>
            <button id="signupBtn" onclick="openModal('signupModal')" class="btn-sm" style="display:none;">Create Custom Account</button>
            <button id="loginBtn" onclick="openModal('loginModal')" class="btn-sm" style="display:none;">Log In</button>
            <button id="logoutBtn" onclick="logout()" class="btn-sm" style="display:none;color:var(--red);border-color:rgba(255,79,106,0.3);">Logout</button>
        </div>
    </div>

    <!-- INBOX TABLE CARD -->
    <div class="tm-card">
        <div style="display:flex;justify-content:space-between;align-items:center;">
            <h2 style="font-size:18px;font-weight:700;">Incoming Messages</h2>
            <span id="msgCountBadge" style="font-size:12px;color:var(--muted);font-family:var(--mono);">0 messages</span>
        </div>

        <div style="overflow-x:auto;">
            <table class="inbox-table">
                <thead>
                    <tr>
                        <th>Sender</th>
                        <th>Subject</th>
                        <th>Date / Time</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="inboxBody">
                    <tr>
                        <td colspan="4" style="text-align:center;padding:32px;color:var(--muted);">
                            No messages received yet. Your inbox auto-refreshes every 5 seconds.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- ─── SIGN UP MODAL ───────────────────────────────────────────────────── -->
<div id="signupModal" class="modal-overlay">
    <div class="modal-card">
        <h3>Create Custom Mail.tm Account</h3>
        <p style="font-size:13px;color:var(--muted);margin-bottom:18px;">Register a custom username and password to keep access to your inbox across sessions.</p>
        
        <form onsubmit="handleSignup(event)">
            <div class="form-group">
                <label>Username / Address Prefix</label>
                <input type="text" id="signupUser" class="form-input" placeholder="myusername" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="signupPass" class="form-input" placeholder="••••••••" required>
            </div>
            <div id="signupErr" style="color:var(--red);font-size:12px;margin-bottom:12px;display:none;"></div>
            
            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
                <button type="button" onclick="closeModal('signupModal')" class="btn-sm">Cancel</button>
                <button type="submit" class="btn-sm btn-green">Register Account</button>
            </div>
        </form>
    </div>
</div>

<!-- ─── LOGIN MODAL ─────────────────────────────────────────────────────── -->
<div id="loginModal" class="modal-overlay">
    <div class="modal-card">
        <h3>Log In to Existing Inbox</h3>
        <p style="font-size:13px;color:var(--muted);margin-bottom:18px;">Enter your temporary email address and password to retrieve saved messages.</p>
        
        <form onsubmit="handleLogin(event)">
            <div class="form-group">
                <label>Full Email Address</label>
                <input type="email" id="loginAddress" class="form-input" placeholder="user@domain.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="loginPass" class="form-input" placeholder="••••••••" required>
            </div>
            <div id="loginErr" style="color:var(--red);font-size:12px;margin-bottom:12px;display:none;"></div>
            
            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
                <button type="button" onclick="closeModal('loginModal')" class="btn-sm">Cancel</button>
                <button type="submit" class="btn-sm btn-green">Log In</button>
            </div>
        </form>
    </div>
</div>

<!-- ─── MESSAGE READ MODAL ─────────────────────────────────────────────── -->
<div id="readModal" class="modal-overlay">
    <div class="modal-card" style="max-width:680px;">
        <h3 id="readSubject">Message Details</h3>
        <div style="font-size:13px;color:var(--muted);margin-bottom:14px;" id="readSender">From: --</div>
        
        <div id="readBody" style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:16px;max-height:360px;overflow-y:auto;font-size:14px;line-height:1.6;margin-bottom:20px;">
            Loading message body...
        </div>
        
        <div style="display:flex;justify-content:space-between;align-items:center;">
            <button id="delMsgBtn" onclick="deleteCurrentMsg()" class="btn-sm" style="color:var(--red);border-color:rgba(255,79,106,0.3);">Delete Message</button>
            <button onclick="closeModal('readModal')" class="btn-sm">Close</button>
        </div>
    </div>
</div>

<!-- ─── FOOTER ─────────────────────────────────────────────────────────── -->
<footer>
    <div class="container">
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/temp-mail">Temp Mail</a>
            <a href="/bulk">Bulk Check</a>
            <a href="/api-docs">API Docs</a>
            <a href="/sitemap.xml">Sitemap</a>
        </div>
        <div>Whoer Live &copy; <span id="yr"></span> — Free IP &amp; Privacy Tools</div>
    </div>
</footer>

<script>
    document.getElementById('yr').textContent = new Date().getFullYear();

    let currentEngine = 'guerrilla';
    let guerrillaSid = localStorage.getItem('g_sid') || null;
    let mailtmToken = localStorage.getItem('tm_token') || null;
    let activeAddress = '';
    let activeMsgId = null;

    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    function switchEngine() {
        currentEngine = document.getElementById('engineSelect').value;
        if (currentEngine === 'mailtm') {
            document.getElementById('signupBtn').style.display = 'inline-block';
            document.getElementById('loginBtn').style.display = 'inline-block';
        } else {
            document.getElementById('signupBtn').style.display = 'none';
            document.getElementById('loginBtn').style.display = 'none';
        }
        generateNewMail();
    }

    async function initTempMail() {
        if (currentEngine === 'guerrilla') {
            await initGuerrillaMail();
        } else {
            if (mailtmToken) {
                await loadMailtmAccountInfo();
            } else {
                await generateMailtmQuick();
            }
        }
    }

    async function generateNewMail() {
        if (currentEngine === 'guerrilla') {
            localStorage.removeItem('g_sid');
            guerrillaSid = null;
            await initGuerrillaMail();
        } else {
            await generateMailtmQuick();
        }
    }

    // ─── GUERRILLA MAIL ENGINE ─────────────
    async function initGuerrillaMail() {
        try {
            document.getElementById('tempEmailVal').textContent = 'Connecting to Guerrilla Mail API...';
            const url = guerrillaSid ? `/api/temp-mail/guerrilla/get_email_address?sid_token=${encodeURIComponent(guerrillaSid)}` : '/api/temp-mail/guerrilla/get_email_address';
            const res = await fetch(url).then(r => r.json());

            if (res.email_addr) {
                activeAddress = res.email_addr;
                guerrillaSid = res.sid_token;
                localStorage.setItem('g_sid', guerrillaSid);
                document.getElementById('tempEmailVal').textContent = activeAddress;
                document.getElementById('accStatus').textContent = 'Status: GuerrillaMail Active (Real OTP Enabled)';
                fetchMessages();
            } else {
                fallback1SecMail();
            }
        } catch(e) {
            fallback1SecMail();
        }
    }

    function fallback1SecMail() {
        const rand = 'whr_' + Math.random().toString(36).substring(2, 9);
        activeAddress = rand + '@1secmail.com';
        document.getElementById('tempEmailVal').textContent = activeAddress;
        fetchMessages();
    }

    // ─── MAIL.TM ENGINE ─────────────────────
    async function generateMailtmQuick() {
        try {
            document.getElementById('tempEmailVal').textContent = 'Creating Mail.tm account...';
            const randomUser = 'whr_' + Math.random().toString(36).substring(2, 10);
            const password = 'pass_' + Math.random().toString(36).substring(2, 10);

            const res = await fetch('/api/temp-mail/accounts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: randomUser, password })
            }).then(r => r.json());

            if (res.success && res.token) {
                mailtmToken = res.token;
                localStorage.setItem('tm_token', mailtmToken);
                await loadMailtmAccountInfo();
            } else {
                fallback1SecMail();
            }
        } catch(e) {
            fallback1SecMail();
        }
    }

    async function loadMailtmAccountInfo() {
        try {
            const res = await fetch('/api/temp-mail/me', {
                headers: { 'Authorization': `Bearer ${mailtmToken}` }
            }).then(r => r.json());

            if (res.success && res.account) {
                activeAddress = res.account.address;
                document.getElementById('tempEmailVal').textContent = activeAddress;
                document.getElementById('accStatus').textContent = 'Status: Mail.tm Authenticated Account';
                document.getElementById('logoutBtn').style.display = 'inline-block';
                fetchMessages();
            } else {
                logout();
            }
        } catch (e) {
            logout();
        }
    }

    // ─── INBOX FETCHING ──────────────────────
    async function fetchMessages() {
        if (!activeAddress && !guerrillaSid && !mailtmToken) return;

        try {
            let msgs = [];
            if (currentEngine === 'guerrilla' && guerrillaSid) {
                const res = await fetch(`/api/temp-mail/guerrilla/get_email_list?sid_token=${encodeURIComponent(guerrillaSid)}`).then(r => r.json());
                msgs = (res.list || []).map(m => ({
                    id: m.mail_id,
                    from: m.mail_from,
                    subject: m.mail_subject,
                    date: m.mail_date,
                    excerpt: m.mail_excerpt
                }));
            } else if (mailtmToken) {
                const res = await fetch('/api/temp-mail/messages', {
                    headers: { 'Authorization': `Bearer ${mailtmToken}` }
                }).then(r => r.json());
                msgs = (res.messages || []).map(m => ({
                    id: m.id,
                    from: m.from ? (m.from.name || m.from.address) : 'Unknown',
                    subject: m.subject,
                    date: m.createdAt
                }));
            }

            document.getElementById('msgCountBadge').textContent = `${msgs.length} messages`;
            const tbody = document.getElementById('inboxBody');

            if (msgs.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="4" style="text-align:center;padding:32px;color:var(--muted);">
                            No messages received yet. Your inbox auto-refreshes every 5 seconds.
                        </td>
                    </tr>
                `;
            } else {
                tbody.innerHTML = msgs.map(m => `
                    <tr onclick="readMessage('${m.id}')">
                        <td style="font-weight:600;">${m.from}</td>
                        <td>${m.subject || '(No Subject)'}</td>
                        <td style="font-family:var(--mono);font-size:12px;color:var(--muted);">${m.date}</td>
                        <td><button class="btn-sm btn-green">Read Email</button></td>
                    </tr>
                `).join('');
            }
        } catch(e) {}
    }

    async function readMessage(id) {
        activeMsgId = id;
        openModal('readModal');
        document.getElementById('readBody').textContent = 'Fetching message contents...';

        try {
            if (currentEngine === 'guerrilla' && guerrillaSid) {
                const res = await fetch(`/api/temp-mail/guerrilla/fetch_email?sid_token=${encodeURIComponent(guerrillaSid)}&email_id=${encodeURIComponent(id)}`).then(r => r.json());
                document.getElementById('readSubject').textContent = res.mail_subject || '(No Subject)';
                document.getElementById('readSender').textContent = `From: ${res.mail_from || 'Unknown'}`;
                document.getElementById('readBody').innerHTML = res.mail_body || `<pre>${res.mail_excerpt || 'No body text'}</pre>`;
            } else if (mailtmToken) {
                const res = await fetch(`/api/temp-mail/messages/${id}`, {
                    headers: { 'Authorization': `Bearer ${mailtmToken}` }
                }).then(r => r.json());
                if (res.success && res.message) {
                    document.getElementById('readSubject').textContent = res.message.subject || '(No Subject)';
                    document.getElementById('readSender').textContent = `From: ${res.message.from ? (res.message.from.address || res.message.from) : 'Unknown'}`;
                    document.getElementById('readBody').innerHTML = res.message.html ? res.message.html : `<pre style="white-space:pre-wrap;">${res.message.text || 'Empty body'}</pre>`;
                }
            }
        } catch(e) {
            document.getElementById('readBody').textContent = 'Failed to load email message.';
        }
    }

    async function deleteCurrentMsg() {
        if (!activeMsgId) return;
        closeModal('readModal');
        fetchMessages();
    }

    function copyAddress() {
        navigator.clipboard.writeText(activeAddress).then(() => {
            const btn = document.getElementById('copyBtn');
            btn.textContent = '✓ Copied!';
            setTimeout(() => btn.textContent = '📋 Copy Address', 2000);
        });
    }

    function logout() {
        localStorage.removeItem('tm_token');
        mailtmToken = null;
        document.getElementById('logoutBtn').style.display = 'none';
        generateNewMail();
    }

    document.addEventListener('DOMContentLoaded', () => {
        initTempMail();
        setInterval(fetchMessages, 5000);
    });
</script>
</body>
</html>
