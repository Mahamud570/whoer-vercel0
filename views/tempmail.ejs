</div>

<!-- ─── FOOTER ─────────────────────────────────────────────────────────── -->
<footer>
    <div class="container">
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/temp-mail">Temp Mail</a>
            <a href="/bulk">Bulk Check</a>
            <a href="/api-docs">API Docs</a>
            <a href="/sitemap.xml">Sitemap</a>
        </div>
        <div>Whoer Live &copy; <span id="yr"></span> — Free IP &amp; Privacy Tools</div>
    </div>
</footer>

<script>
    document.getElementById('yr').textContent = new Date().getFullYear();

    let activeEngine = 'mailtm'; // mailtm | guerrilla | secmail
    let mailtmToken = localStorage.getItem('tm_token') || null;
    let currentAddress = localStorage.getItem('tm_addr') || '';
    let currentPass = localStorage.getItem('tm_pass') || '';
    let guerrillaSid = localStorage.getItem('g_sid') || null;
    let isPassVisible = false;
    let activeMsgId = null;

    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    async function initTempMail() {
        await loadDomains();
        if (mailtmToken) {
            await loadMailtmAccountInfo();
        } else {
            await generateMailtmQuick();
        }
    }

    async function loadDomains() {
        try {
            let domains = ['web-library.net', 'mail.tm'];
            try {
                const res = await fetch('https://api.mail.tm/domains').then(r => r.json());
                if (res['hydra:member'] && res['hydra:member'].length) {
                    domains = res['hydra:member'].map(d => d.domain);
                }
            } catch(e) {
                const res = await fetch('/api/temp-mail/domains').then(r => r.json());
                if (res.domains) domains = res.domains;
            }
            const select = document.getElementById('signupDomain');
            select.innerHTML = domains.map(d => `<option value="${d}">${d}</option>`).join('');
        } catch(e) {}
    }

    async function generateMailtmQuick() {
        try {
            document.getElementById('tempEmailVal').textContent = 'Creating active account...';
            const randomUser = 'whr_' + Math.random().toString(36).substring(2, 10);
            const password = 'pass_' + Math.random().toString(36).substring(2, 10);

            // 1. Direct CORS fetch to Mail.tm API
            try {
                const dRes = await fetch('https://api.mail.tm/domains').then(r => r.json());
                const domain = (dRes['hydra:member'] && dRes['hydra:member'].length) ? dRes['hydra:member'][0].domain : 'web-library.net';
                const address = `${randomUser}@${domain}`;

                await fetch('https://api.mail.tm/accounts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ address, password })
                });

                const tokRes = await fetch('https://api.mail.tm/token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ address, password })
                }).then(r => r.json());

                if (tokRes.token) {
                    activeEngine = 'mailtm';
                    mailtmToken = tokRes.token;
                    currentAddress = address;
                    currentPass = password;
                    localStorage.setItem('tm_token', mailtmToken);
                    localStorage.setItem('tm_addr', currentAddress);
                    localStorage.setItem('tm_pass', currentPass);
                    updateUI();
                    fetchMessages();
                    return;
                }
            } catch(directErr) {}

            // 2. Server proxy fallback
            const res = await fetch('/api/temp-mail/accounts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: randomUser, password })
            }).then(r => r.json());

            if (res.success && res.token) {
                activeEngine = 'mailtm';
                mailtmToken = res.token;
                currentAddress = res.address;
                currentPass = password;
                localStorage.setItem('tm_token', mailtmToken);
                localStorage.setItem('tm_addr', currentAddress);
                localStorage.setItem('tm_pass', currentPass);
                updateUI();
                fetchMessages();
            } else {
                await fallbackGuerrillaMail();
            }
        } catch(e) {
            await fallbackGuerrillaMail();
        }
    }

    async function fallbackGuerrillaMail() {
        try {
            document.getElementById('tempEmailVal').textContent = 'Connecting to Guerrilla Mail...';
            const url = guerrillaSid ? `/api/temp-mail/guerrilla/get_email_address?sid_token=${encodeURIComponent(guerrillaSid)}` : '/api/temp-mail/guerrilla/get_email_address';
            let res = null;
            try {
                res = await fetch('https://api.guerrillamail.com/ajax.php?f=get_email_address').then(r => r.json());
            } catch(e) {
                res = await fetch(url).then(r => r.json());
            }

            if (res && res.email_addr) {
                activeEngine = 'guerrilla';
                currentAddress = res.email_addr;
                guerrillaSid = res.sid_token;
                currentPass = '';
                localStorage.setItem('g_sid', guerrillaSid);
                updateUI();
                fetchMessages();
            } else {
                fallback1SecMail();
            }
        } catch(e) {
            fallback1SecMail();
        }
    }

    function fallback1SecMail() {
        activeEngine = 'secmail';
        const rand = 'whr_' + Math.random().toString(36).substring(2, 9);
        currentAddress = rand + '@1secmail.com';
        currentPass = '';
        updateUI();
        fetchMessages();
    }

    async function loadMailtmAccountInfo() {
        try {
            let res = null;
            try {
                res = await fetch('https://api.mail.tm/me', {
                    headers: { 'Authorization': `Bearer ${mailtmToken}` }
                }).then(r => r.json());
            } catch(e) {
                res = await fetch('/api/temp-mail/me', {
                    headers: { 'Authorization': `Bearer ${mailtmToken}` }
                }).then(r => r.json());
            }

            if (res && (res.address || (res.success && res.account))) {
                activeEngine = 'mailtm';
                currentAddress = res.address || res.account.address;
                updateUI();
                fetchMessages();
            } else {
                await fallbackGuerrillaMail();
            }
        } catch (e) {
            await fallbackGuerrillaMail();
        }
    }

    function updateUI() {
        document.getElementById('tempEmailVal').textContent = currentAddress || 'Generating email...';
        document.getElementById('accStatus').textContent = currentAddress ? `Status: Active (${currentAddress})` : 'Status: Initializing';
        
        const credBanner = document.getElementById('credBanner');
        if (activeEngine === 'mailtm' && currentPass) {
            credBanner.style.display = 'flex';
            renderPassVal();
        } else {
            credBanner.style.display = 'none';
        }
    }

    function renderPassVal() {
        const passSpan = document.getElementById('passVal');
        if (!currentPass) {
            passSpan.textContent = '••••••••';
        } else if (isPassVisible) {
            passSpan.textContent = currentPass;
        } else {
            passSpan.textContent = '••••••••';
        }
    }

    function togglePassVisibility() {
        isPassVisible = !isPassVisible;
        const btn = document.getElementById('togglePassBtn');
        btn.textContent = isPassVisible ? '🙈 Hide Password' : '👁️ Show Password';
        renderPassVal();
    }

    function copyPassword() {
        if (!currentPass || currentPass.includes('Session')) {
            alert('Password not available for this session. Please create a custom account or generate a Mail.tm email.');
            return;
        }
        
        navigator.clipboard.writeText(currentPass).then(() => {
            const btn = document.getElementById('copyPassBtn');
            btn.textContent = '✓ Copied!';
            setTimeout(() => { btn.textContent = '📋 Copy Password'; }, 2000);
        }).catch(() => {
            const ta = document.createElement('textarea');
            ta.value = currentPass;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            const btn = document.getElementById('copyPassBtn');
            btn.textContent = '✓ Copied!';
            setTimeout(() => { btn.textContent = '📋 Copy Password'; }, 2000);
        });
    }

    async function handleSignup(e) {
        e.preventDefault();
        const rawUser = document.getElementById('signupUser').value.trim().toLowerCase();
        const cleanUser = rawUser.replace(/[^a-z0-9._-]/g, '');
        const domainSelect = document.getElementById('signupDomain');
        const domain = (domainSelect && domainSelect.value) ? domainSelect.value : 'web-library.net';
        const pass = document.getElementById('signupPass').value.trim();
        const fullAddr = cleanUser.includes('@') ? cleanUser : `${cleanUser}@${domain}`;
        const errDiv = document.getElementById('signupErr');
        errDiv.style.display = 'none';

        if (!cleanUser) {
            errDiv.textContent = 'Please enter a valid username.';
            errDiv.style.display = 'block';
            return;
        }
        if (pass.length < 6) {
            errDiv.textContent = 'Password must be at least 6 characters.';
            errDiv.style.display = 'block';
            return;
        }

        // Direct CORS signup to Mail.tm from client
        try {
            await fetch('https://api.mail.tm/accounts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ address: fullAddr, password: pass })
            });

            const tokRes = await fetch('https://api.mail.tm/token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ address: fullAddr, password: pass })
            }).then(r => r.json());

            if (tokRes.token) {
                activeEngine = 'mailtm';
                mailtmToken = tokRes.token;
                currentAddress = fullAddr;
                currentPass = pass;
                localStorage.setItem('tm_token', mailtmToken);
                localStorage.setItem('tm_addr', currentAddress);
                localStorage.setItem('tm_pass', currentPass);
                closeModal('signupModal');
                updateUI();
                fetchMessages();
                return;
            }
        } catch(cErr) {}

        // Proxy Fallback
        try {
            const res = await fetch('/api/temp-mail/accounts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: fullAddr, password: pass })
            }).then(r => r.json());

            if (res.success && res.token) {
                activeEngine = 'mailtm';
                mailtmToken = res.token;
                currentAddress = res.address;
                currentPass = pass;
                localStorage.setItem('tm_token', mailtmToken);
                localStorage.setItem('tm_addr', currentAddress);
                localStorage.setItem('tm_pass', currentPass);
                closeModal('signupModal');
                updateUI();
                fetchMessages();
            } else {
                errDiv.textContent = res.error || 'Account creation failed. Try another username.';
                errDiv.style.display = 'block';
            }
        } catch(err) {
            errDiv.textContent = 'Registration failed. Try another username.';
            errDiv.style.display = 'block';
        }
    }

    async function handleLogin(e) {
        e.preventDefault();
        const address = document.getElementById('loginAddress').value.trim().toLowerCase();
        const pass = document.getElementById('loginPass').value.trim();
        const errDiv = document.getElementById('loginErr');
        errDiv.style.display = 'none';

        // Direct CORS Login to Mail.tm from client
        try {
            const tokRes = await fetch('https://api.mail.tm/token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ address, password: pass })
            }).then(r => r.json());

            if (tokRes.token) {
                activeEngine = 'mailtm';
                mailtmToken = tokRes.token;
                currentAddress = address;
                currentPass = pass;
                localStorage.setItem('tm_token', mailtmToken);
                localStorage.setItem('tm_addr', currentAddress);
                localStorage.setItem('tm_pass', currentPass);
                closeModal('loginModal');
                updateUI();
                fetchMessages();
                return;
            }
        } catch(cErr) {}

        // Proxy Fallback
        try {
            const res = await fetch('/api/temp-mail/token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ address, password: pass })
            }).then(r => r.json());

            if (res.success && res.token) {
                activeEngine = 'mailtm';
                mailtmToken = res.token;
                currentAddress = address;
                currentPass = pass;
                localStorage.setItem('tm_token', mailtmToken);
                localStorage.setItem('tm_addr', currentAddress);
                localStorage.setItem('tm_pass', currentPass);
                closeModal('loginModal');
                updateUI();
                fetchMessages();
            } else {
                errDiv.textContent = res.error || 'Invalid address or password.';
                errDiv.style.display = 'block';
            }
        } catch(err) {
            errDiv.textContent = 'Login failed.';
            errDiv.style.display = 'block';
        }
    }

    async function fetchMessages() {
        if (!currentAddress && !mailtmToken && !guerrillaSid) return;

        try {
            let msgs = [];
            if (activeEngine === 'mailtm' && mailtmToken) {
                let res = null;
                try {
                    res = await fetch('https://api.mail.tm/messages', {
                        headers: { 'Authorization': `Bearer ${mailtmToken}` }
                    }).then(r => r.json());
                    msgs = (res['hydra:member'] || []).map(m => ({
                        id: m.id,
                        from: m.from ? (m.from.name || m.from.address) : 'Unknown',
                        subject: m.subject || '(No Subject)',
                        date: new Date(m.createdAt || Date.now()).toLocaleTimeString()
                    }));
                } catch(e) {
                    res = await fetch('/api/temp-mail/messages', {
                        headers: { 'Authorization': `Bearer ${mailtmToken}` }
                    }).then(r => r.json());
                    msgs = (res.messages || []).map(m => ({
                        id: m.id,
                        from: m.from ? (m.from.name || m.from.address) : 'Unknown',
                        subject: m.subject || '(No Subject)',
                        date: new Date(m.createdAt || Date.now()).toLocaleTimeString()
                    }));
                }
            } else if (activeEngine === 'guerrilla' && guerrillaSid) {
                let res = null;
                try {
                    res = await fetch(`https://api.guerrillamail.com/ajax.php?f=get_email_list&sid_token=${encodeURIComponent(guerrillaSid)}&offset=0`).then(r => r.json());
                } catch(e) {
                    res = await fetch(`/api/temp-mail/guerrilla/get_email_list?sid_token=${encodeURIComponent(guerrillaSid)}`).then(r => r.json());
                }
                msgs = (res.list || []).map(m => ({
                    id: m.mail_id,
                    from: m.mail_from,
                    subject: m.mail_subject,
                    date: m.mail_date
                }));
            } else if (activeEngine === 'secmail') {
                const [login, domain] = currentAddress.split('@');
                const res = await fetch(`https://www.1secmail.com/api/v1/?action=getMessages&login=${login}&domain=${domain}`).then(r => r.json());
                msgs = (res || []).map(m => ({
                    id: m.id,
                    from: m.from,
                    subject: m.subject,
                    date: m.date
                }));
            }

            document.getElementById('msgCountBadge').textContent = `${msgs.length} messages`;
            const tbody = document.getElementById('inboxBody');

            if (msgs.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="4" style="text-align:center;padding:32px;color:var(--muted);">
                            No messages received yet. Auto-checking every 5 seconds...
                        </td>
                    </tr>
                `;
            } else {
                tbody.innerHTML = msgs.map(m => `
                    <tr onclick="readMessage('${m.id}')">
                        <td style="font-weight:600;">${m.from}</td>
                        <td>${m.subject}</td>
                        <td style="font-family:var(--mono);font-size:12px;color:var(--muted);">${m.date}</td>
                        <td><button class="btn-sm btn-green">Read Email</button></td>
                    </tr>
                `).join('');
            }
        } catch(e) {}
    }

    async function readMessage(id) {
        activeMsgId = id;
        openModal('readModal');
        document.getElementById('readBody').textContent = 'Fetching message contents...';

        try {
            if (activeEngine === 'mailtm' && mailtmToken) {
                let res = null;
                try {
                    res = await fetch(`https://api.mail.tm/messages/${id}`, {
                        headers: { 'Authorization': `Bearer ${mailtmToken}` }
                    }).then(r => r.json());
                    if (res && res.subject) {
                        document.getElementById('readSubject').textContent = res.subject || '(No Subject)';
                        document.getElementById('readSender').textContent = `From: ${res.from ? (res.from.address || res.from) : 'Unknown'}`;
                        document.getElementById('readBody').innerHTML = res.html ? res.html.join('') : `<pre style="white-space:pre-wrap;">${res.text || 'Empty body'}</pre>`;
                        return;
                    }
                } catch(e) {}
                
                res = await fetch(`/api/temp-mail/messages/${id}`, {
                    headers: { 'Authorization': `Bearer ${mailtmToken}` }
                }).then(r => r.json());
                if (res.success && res.message) {
                    document.getElementById('readSubject').textContent = res.message.subject || '(No Subject)';
                    document.getElementById('readSender').textContent = `From: ${res.message.from ? (res.message.from.address || res.message.from) : 'Unknown'}`;
                    document.getElementById('readBody').innerHTML = res.message.html ? res.message.html : `<pre style="white-space:pre-wrap;">${res.message.text || 'Empty body'}</pre>`;
                }
            } else if (activeEngine === 'guerrilla' && guerrillaSid) {
                let res = null;
                try {
                    res = await fetch(`https://api.guerrillamail.com/ajax.php?f=fetch_email&sid_token=${encodeURIComponent(guerrillaSid)}&email_id=${encodeURIComponent(id)}`).then(r => r.json());
                } catch(e) {
                    res = await fetch(`/api/temp-mail/guerrilla/fetch_email?sid_token=${encodeURIComponent(guerrillaSid)}&email_id=${encodeURIComponent(id)}`).then(r => r.json());
                }
                document.getElementById('readSubject').textContent = res.mail_subject || '(No Subject)';
                document.getElementById('readSender').textContent = `From: ${res.mail_from || 'Unknown'}`;
                document.getElementById('readBody').innerHTML = res.mail_body || `<pre>${res.mail_excerpt || 'No text'}</pre>`;
            } else if (activeEngine === 'secmail') {
                const [login, domain] = currentAddress.split('@');
                const res = await fetch(`https://www.1secmail.com/api/v1/?action=readMessage&login=${login}&domain=${domain}&id=${id}`).then(r => r.json());
                document.getElementById('readSubject').textContent = res.subject || '(No Subject)';
                document.getElementById('readSender').textContent = `From: ${res.from || 'Unknown'}`;
                document.getElementById('readBody').innerHTML = res.htmlBody ? res.htmlBody : `<pre>${res.textBody || 'Empty body'}</pre>`;
            }
        } catch(e) {
            document.getElementById('readBody').textContent = 'Error reading email.';
        }
    }

    async function deleteCurrentMsg() {
        if (!activeMsgId) return;
        try {
            if (activeEngine === 'mailtm' && mailtmToken) {
                try {
                    await fetch(`https://api.mail.tm/messages/${activeMsgId}`, {
                        method: 'DELETE',
                        headers: { 'Authorization': `Bearer ${mailtmToken}` }
                    });
                } catch(e) {
                    await fetch(`/api/temp-mail/messages/${activeMsgId}`, {
                        method: 'DELETE',
                        headers: { 'Authorization': `Bearer ${mailtmToken}` }
                    });
                }
            }
            closeModal('readModal');
            fetchMessages();
        } catch(e) {}
    }

    function copyAddress() {
        navigator.clipboard.writeText(currentAddress).then(() => {
            const btn = document.getElementById('copyBtn');
            btn.textContent = '✓ Copied!';
            setTimeout(() => btn.textContent = '📋 Copy Email', 2000);
        });
    }

    function logout() {
        localStorage.removeItem('tm_token');
        localStorage.removeItem('tm_addr');
        localStorage.removeItem('tm_pass');
        localStorage.removeItem('g_sid');
        mailtmToken = null;
        guerrillaSid = null;
        currentAddress = '';
        currentPass = '';
        updateUI();
        generateMailtmQuick();
    }

    document.addEventListener('DOMContentLoaded', () => {
        initTempMail();
        setInterval(fetchMessages, 5000);
    });
</script>
</body>
</html>
