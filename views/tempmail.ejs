    <style>
        .tm-wrap { max-width: 960px; margin: 0 auto; padding: 20px 20px 100px; }
        .tm-hero { text-align: center; padding: 40px 0 28px; }
        .tm-hero h1 { font-family: var(--serif); font-size: 36px; font-weight: 700; margin-bottom: 12px; letter-spacing: -0.5px; }
        .tm-hero p { font-size: 15px; color: var(--muted); max-width: 560px; margin: 0 auto; line-height: 1.7; }

        .tm-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin-bottom: 20px; }
        .tm-box { display: flex; align-items: center; justify-content: space-between; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px 18px; margin-top: 14px; gap: 12px; flex-wrap: wrap; }
        .tm-address { font-family: var(--mono); font-size: 18px; font-weight: 600; color: var(--accent); word-break: break-all; }

        .cred-row { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 12px 16px; border-radius: var(--radius-sm); margin-top: 12px; font-size: 13px; flex-wrap: wrap; }
        .cred-label { color: var(--muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
        .cred-val { font-family: var(--mono); color: var(--text); font-size: 14px; font-weight: 500; letter-spacing: 0.3px; }

        .tm-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; align-items: center; }
        .btn-sm { padding: 7px 14px; font-size: 12px; border-radius: var(--radius-sm); font-weight: 500; cursor: pointer; text-decoration: none; border: 1px solid var(--border2); background: transparent; color: var(--text); transition: all 0.15s; font-family: var(--sans); }
        .btn-sm:hover { background: var(--panel-hover); border-color: rgba(255,255,255,0.18); }
        .btn-sm.btn-green { background: var(--accent); color: #0E0C04; border-color: var(--accent); font-weight: 600; }
        .btn-sm.btn-green:hover { background: #D4B46A; border-color: #D4B46A; }

        .inbox-table { width: 100%; border-collapse: collapse; margin-top: 14px; font-size: 13px; }
        .inbox-table th { text-align: left; padding: 10px 12px; color: var(--muted); border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
        .inbox-table td { padding: 14px 12px; border-bottom: 1px solid var(--border); color: var(--text); }
        .inbox-table tr:hover td { background: var(--panel-hover); cursor: pointer; }

        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center; padding: 20px; }
        .modal-card { background: var(--bg2); border: 1px solid var(--border2); border-radius: var(--radius); max-width: 520px; width: 100%; padding: 32px; box-shadow: 0 24px 64px rgba(0,0,0,0.7); }
        .modal-card h3 { font-family: var(--serif); font-size: 22px; font-weight: 700; margin-bottom: 20px; }
        .form-group { margin-bottom: 14px; text-align: left; }
        .form-group label { display: block; font-size: 11px; color: var(--muted); margin-bottom: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
        .form-input { width: 100%; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border2); border-radius: var(--radius-sm); color: var(--text); font-family: var(--mono); font-size: 14px; box-sizing: border-box; transition: border-color 0.15s; }
        .form-input:focus { border-color: var(--accent); outline: none; }
        .form-select { width: 100%; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border2); border-radius: var(--radius-sm); color: var(--text); font-size: 14px; outline: none; transition: border-color 0.15s; }
        .form-select:focus { border-color: var(--accent); }
