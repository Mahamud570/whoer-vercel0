            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
                <button type="button" onclick="closeModal('loginModal')" class="btn-sm">Cancel</button>
                <button type="submit" class="btn-sm btn-green">Log In</button>
            </div>
        </form>
