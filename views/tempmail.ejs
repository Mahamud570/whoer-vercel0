</div>

<!-- ─── SIGN UP MODAL ───────────────────────────────────────────────────── -->
<div id="signupModal" class="modal-overlay">
    <div class="modal-card">
        <h3>Create Custom Mail.tm Account</h3>
        <p style="font-size:13px;color:var(--muted);margin-bottom:18px;">Register your custom username &amp; password. You can log in anytime to check saved messages.</p>
        
        <form onsubmit="handleSignup(event)">
            <div class="form-group">
