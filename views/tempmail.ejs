<!-- ─── MAIN CONTENT ────────────────────────────────────────────────────── -->
<div class="tm-wrap">
    
    <div class="tm-hero">
        <h1>Temporary Email Account System</h1>
        <p>Mail.tm style disposable email accounts. Register a custom address or use auto-generated credentials to log in anytime and retrieve your messages.</p>
    </div>

    <!-- ACTIVE EMAIL CARD -->
    <div class="tm-card">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
            <div>
                <span style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;">Active Account Address</span>
