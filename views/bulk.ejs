<script>
document.getElementById('yr').textContent = new Date().getFullYear();
let allResults = [];
let allParsed  = [];

// ─── Parser: extract IP, port, type, credentials from any proxy string ────────
function parseProxyLine(raw) {
    const line = (raw || '').trim();
    if (!line) return null;

    let type = 'IP', ip = '', port = '', user = '', pass = '';

    // Detect scheme prefix
    const schemeMatch = line.match(/^(https?|socks5?|socks4a?|ss):\/\//i);
    if (schemeMatch) {
        const scheme = schemeMatch[1].toLowerCase();
        type = scheme === 'http' ? 'HTTP'
             : scheme === 'https' ? 'HTTPS'
             : scheme === 'ss'    ? 'SS'
             : scheme === 'socks4' || scheme === 'socks4a' ? 'SOCKS4'
             : scheme === 'socks5' ? 'SOCKS5'
             : 'SOCKS';

        let rest = line.slice(schemeMatch[0].length);

        // Shadowsocks: ss://base64encodedMethod@host:port or ss://base64@host:port
        if (type === 'SS') {
            const atIdx = rest.lastIndexOf('@');
            if (atIdx !== -1) rest = rest.slice(atIdx + 1);
            else {
                // Try base64 decode to extract host
                try {
                    const decoded = atob(rest.split('#')[0].split('/')[0]);
                    const m = decoded.match(/@([\d.a-fA-F:]+):(\d+)/);
                    if (m) { ip = m[1]; port = m[2]; return { type, ip, port, user, pass }; }
                } catch(_) {}
            }
        }

        // user:pass@host:port
        const atMatch = rest.match(/^([^@]+):([^@]+)@(.+)/);
        if (atMatch) { user = atMatch[1]; pass = atMatch[2]; rest = atMatch[3]; }

        const hostPort = rest.split('/')[0]; // strip path
        const hp = splitHostPort(hostPort);
        ip = hp.ip; port = hp.port;
        if (type === 'IP' && port) type = 'HTTP';
        return { type, ip, port, user, pass };
    }

    // No scheme — try various plain formats
    // user:pass@ip:port
    const atMatch = line.match(/^([^@:]+):([^@]+)@([\d.a-fA-F:]+):(\d+)$/);
    if (atMatch) {
        user = atMatch[1]; pass = atMatch[2];
        ip = atMatch[3]; port = atMatch[4];
        type = 'HTTP';
        return { type, ip, port, user, pass };
    }

    // ip:port:user:pass
    const colonSplit = line.split(':');
    if (colonSplit.length >= 4 && /^\d+$/.test(colonSplit[1])) {
        ip   = colonSplit[0];
        port = colonSplit[1];
        user = colonSplit[2];
        pass = colonSplit.slice(3).join(':');
        type = 'HTTP';
        return { type, ip, port, user, pass };
    }

    // ip:port
    if (colonSplit.length === 2 && /^\d+$/.test(colonSplit[1])) {
        ip   = colonSplit[0];
        port = colonSplit[1];
        type = 'HTTP';
        return { type, ip, port, user, pass };
    }

    // bare IP or IPv6
    if (/^[\d.]+$/.test(line) || /^[a-fA-F0-9:]+$/.test(line)) {
        ip = line; type = 'IP';
        return { type, ip, port, user, pass };
    }

    return null; // unrecognised
}

function splitHostPort(str) {
    // Handle IPv6 [::1]:port
    const ipv6 = str.match(/^\[([^\]]+)\]:(\d+)$/);
    if (ipv6) return { ip: ipv6[1], port: ipv6[2] };
    const parts = str.split(':');
    if (parts.length === 2) return { ip: parts[0], port: parts[1] };
    return { ip: str, port: '' };
}

function isValidIP(ip) {
    return /^(\d{1,3}\.){3}\d{1,3}$/.test(ip) || /^[a-fA-F0-9:]{2,39}$/.test(ip);
}

function updateCounter() {
    const lines = document.getElementById('ipInput').value
        .split('\n').map(l => l.trim()).filter(Boolean);
    document.getElementById('ipCount').textContent = Math.min(lines.length, 100);
}

async function runBulkCheck() {
    const raw = document.getElementById('ipInput').value
        .split('\n').map(l => l.trim()).filter(Boolean).slice(0, 100);
    if (!raw.length) return;

    // Parse all lines
    allParsed = raw.map(line => parseProxyLine(line)).filter(Boolean);
    const validIPs = [...new Set(allParsed.map(p => p.ip).filter(isValidIP))];

    if (!validIPs.length) { alert('No valid IP addresses found.'); return; }

    const btn = document.getElementById('checkBtn');
    btn.disabled = true;
    btn.textContent = 'Checking…';

    const term = document.getElementById('scanTerminal');
    const logs = document.getElementById('termLogs');
    const tbar = document.getElementById('termBar');

    term.classList.add('on');
    logs.innerHTML = '';
    tbar.style.width = '0%';

    // Generate terminal stages
    const stages = [
        '<span class="sys">[SYS]</span> Initializing bulk scan container...',
        '<span class="sys">[SYS]</span> Waking up proxy tester nodes...'
    ];
    
    // Add fake logs per proxy
    validIPs.forEach(ip => {
        stages.push(`<span class="sys">[NET]</span> Connecting -> <span class="ip">${ip}</span>...`);
        stages.push(`<span class="sys">[CHK]</span> Resolving GeoIP & ISP for <span class="ip">${ip}</span>...`);
        stages.push(`<span class="sys">[SEC]</span> Cross-referencing <span class="ip">${ip}</span> against VPN blacklists...`);
    });

    let sIdx = 0;
    const termItv = setInterval(() => {
        if (sIdx < stages.length) {
            const div = document.createElement('div');
            div.className = 'term-log';
            div.innerHTML = stages[sIdx];
            logs.appendChild(div);
            logs.scrollTop = logs.scrollHeight;
            const pct = Math.floor((sIdx / stages.length) * 96);
            tbar.style.width = pct + '%';
            sIdx++;
        }
    }, Math.max(80, 2000 / stages.length)); // Speed it up based on total IPs

    try {
        const res = await fetch('/api/bulk-scan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ips: validIPs }),
        });
        clearInterval(termItv);
        const data = await res.json();
        tbar.style.width = '100%';
        const div = document.createElement('div');
        div.className = 'term-log';
        div.innerHTML = `<span class="sys" style="color:var(--green)">[SYS] Scan complete! Downloading artifacts...</span>`;
        logs.appendChild(div);
        logs.scrollTop = logs.scrollHeight;

        // Map results back by IP
        const byIP = {};
        (data.results || []).forEach(r => { byIP[r.ip] = r; });

        allResults = allParsed.map(p => ({
            ...p,
            geo: byIP[p.ip] || { error: true, ip: p.ip },
        }));

        setTimeout(() => { 
            term.classList.remove('on'); 
            renderResults(allResults); 
        }, 1200);
    } catch(e) {
        clearInterval(termItv);
        alert('Error. Please try again.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Check All`;
    }
}

function typeBadge(type) {
    const cls = { HTTP:'t-http', HTTPS:'t-https', SOCKS:'t-socks', SOCKS4:'t-socks4', SOCKS5:'t-socks5', SS:'t-ss', IP:'t-ip' }[type] || 't-ip';
    return `<span class="type-badge ${cls}">${type}</span>`;
}

function renderResults(results) {
    const body = document.getElementById('resultsBody');
    const meta = document.getElementById('resultsMeta');
    const ok   = results.filter(r => !r.geo.error).length;
    meta.textContent = `${ok} of ${results.length} resolved`;

    body.innerHTML = results.map((r, i) => {
        const g = r.geo;
        if (g.error) return `
            <tr>
                <td class="muted">${i+1}</td>
                <td>${typeBadge(r.type)}</td>
                <td class="mono">${r.ip || '—'}</td>
                <td class="muted">${r.port || '—'}</td>
                <td class="muted vpn-err" colspan="3">Could not resolve</td>
                <td><span class="vpn-err">—</span></td>
            </tr>`;
        const flag = g.countryCode
            ? `<img class="flag-img" src="https://flagcdn.com/w40/${g.countryCode.toLowerCase()}.png" alt="${g.country}">`
            : '';
        return `
            <tr>
                <td class="muted">${i+1}</td>
                <td>${typeBadge(r.type)}</td>
                <td class="mono">${g.ip}</td>
                <td class="muted">${r.port || '—'}</td>
                <td>${flag}${g.country}</td>
                <td class="muted">${g.city}</td>
                <td class="muted" style="max-width:200px;word-break:break-word;font-size:11px;">${g.isp}</td>
                <td>${g.is_vpn ? '<span class="vpn-yes">VPN/DC</span>' : '<span class="vpn-no">Clean</span>'}</td>
            </tr>`;
    }).join('');

    document.getElementById('bulkResults').classList.add('visible');
}

function clearResults() {
    document.getElementById('bulkResults').classList.remove('visible');
    document.getElementById('ipInput').value = '';
    document.getElementById('ipCount').textContent = '0';
    allResults = []; allParsed = [];
}

function downloadCSV() {
    if (!allResults.length) return;
    const header = ['#','Type','IP','Port','User','Country','City','ISP','Timezone','VPN/DC'];
    const rows = allResults.map((r, i) => {
        const g = r.geo;
        return [i+1, r.type, g.ip||r.ip, r.port, r.user,
            g.error?'Error':g.country, g.error?'':g.city,
            g.error?'':g.isp, g.error?'':g.timezone,
            g.error?'':g.is_vpn?'Yes':'No'];
    });
    const csv = [header,...rows].map(r=>r.map(c=>`"${(c||'').toString().replace(/"/g,'""')}"`).join(',')).join('\n');
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
    a.download = 'whoer-bulk-results.csv';
    a.click();
}
</script>
</body>
</html>
