    <!-- ─── DEEP ANALYZER PREMIUM LOCK ──────────────────────────────────────── -->
    <div class="panel" style="margin-bottom:20px; border-color: rgba(255, 79, 106, 0.4); background: rgba(255, 79, 106, 0.05); text-align:center; padding:40px 20px;">
        <h3 style="color:var(--red); margin-bottom:10px; font-weight:700; font-family:var(--mono); letter-spacing:1px; font-size:16px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> 
