<script src="/js/fp.js"></script>
<script>
document.getElementById('yr').textContent = new Date().getFullYear();

// ─── Scan steps animation ────────────────────────────────────────────────────
function stepDone(n) {
    const el = document.getElementById('step' + n);
    const next = document.getElementById('step' + (n+1));
    if (el) el.classList.replace('active', 'done');
    if (next) next.classList.add('active');
}

// ─── Copy IP ─────────────────────────────────────────────────────────────────
function copyIP() {
    const ip  = document.getElementById('ipDisplay').textContent;
    const btn = document.getElementById('copyBtn');
    if (ip === '···') return;
    navigator.clipboard.writeText(ip).then(() => {
        btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        btn.classList.add('ok');
        setTimeout(() => {
            btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
            btn.classList.remove('ok');
        }, 2000);
    });
}

// ─── Score helpers ───────────────────────────────────────────────────────────
function scoreClass(s) {
    if (s >= 85) return '';
    if (s >= 55) return 'warn';
    return 'risk';
}

function scoreMsg(s) {
    if (s === 100) return 'Fully protected';
    if (s >= 85)  return 'Mostly clean';
    if (s >= 55)  return 'Some risks detected';
    return 'High risk — action needed';
}

// ─── Render report ───────────────────────────────────────────────────────────
function renderReport(r) {
    const ip = r.ip_data;
    const br = r.browser_data;

    // IP / Hero
    document.getElementById('ipDisplay').textContent = ip.ip;
    document.getElementById('ipDisplay').classList.add('anim-in');

    const cc = (ip.countryCode || '').toLowerCase();
    if (cc) document.getElementById('flagBox').innerHTML =
        `<img src="https://flagcdn.com/w160/${cc}.png" alt="${ip.country}">`;

    const loc = [ip.city, ip.region, ip.country].filter(Boolean).join(', ');
    document.getElementById('locationLine').innerHTML =
        `<span>${loc}</span> <span class="dot-sep">·</span> ${ip.utc_offset || ''}`;

    // Summary cards
    document.getElementById('ispVal').textContent    = ip.isp || '—';
    document.getElementById('osVal').textContent     = br.os || '—';
    document.getElementById('browserVal').textContent = br.browser || '—';
    document.getElementById('tzVal').textContent =
        `${ip.timezone} (${ip.utc_offset || ''})`;

    // Location
    document.getElementById('dCountry').textContent = ip.country || '—';
    document.getElementById('dRegion').textContent  = ip.region  || '—';
    document.getElementById('dCity').textContent    = ip.city    || '—';
    document.getElementById('dZip').textContent     = ip.zip     || 'N/A';
    document.getElementById('dOrg').textContent     = ip.org     || ip.isp || '—';
    document.getElementById('dAsn').textContent     = ip.asn     || 'N/A';

    // Privacy
    document.getElementById('dProxy').innerHTML = ip.is_hosting
        ? `<span class="badge badge-red">Detected</span>`
        : `<span class="badge badge-green">No Proxy</span>`;
    document.getElementById('dAnon').textContent = ip.is_hosting ? 'Yes' : 'No';

    document.getElementById('dBotBadge').innerHTML = br.is_antidetect
        ? `<span class="badge badge-red">Antidetect / Bot</span>`
        : `<span class="badge badge-green">Standard</span>`;

    // WebRTC badge in privacy panel
    const rtcLeaked = br.webrtcLeaked || false;
    document.getElementById('dWebRTC').innerHTML = rtcLeaked
        ? `<span class="badge badge-red">Leaked</span>`
        : `<span class="badge badge-green">No Leak</span>`;

    // Time sync
    document.getElementById('dZone').textContent   = ip.timezone;
    document.getElementById('dLocal').textContent  = ip.local_time;
    document.getElementById('dSystem').textContent = br.system_time;
    const tsBox = document.getElementById('timeSyncBox');
    tsBox.className = 'time-sync-box ' + (br.time_mismatch ? 'bad' : 'ok');

    // WebRTC detail panel
    const webrtcBox  = document.getElementById('webrtcBox');
    const webrtcStat = document.getElementById('webrtcStatus');
    const webrtcList = document.getElementById('webrtcIpList');
    if (rtcLeaked && br.webrtcPublicIps && br.webrtcPublicIps.length) {
        webrtcBox.className = 'webrtc-result leak';
        webrtcStat.textContent = '⚠ Real IP exposed via WebRTC';
        webrtcList.innerHTML = br.webrtcPublicIps.map(ip =>
            `<div class="webrtc-ip">${ip}</div>`).join('');
    } else {
        webrtcBox.className = 'webrtc-result safe';
        webrtcStat.textContent = '✓ No WebRTC leak detected';
    }

    // Fingerprint grid
    document.getElementById('fpCanvas').textContent  = br.canvasHash  || 'Blocked';
    document.getElementById('fpWebgl').textContent   = br.webglHash   || 'N/A';
    document.getElementById('fpAudio').textContent   = br.audioHash   || 'N/A';
    document.getElementById('fpCpu').textContent     = br.hardwareConcurrency || '—';
    document.getElementById('fpRam').textContent     = br.deviceMemory !== 'unknown'
        ? (br.deviceMemory + ' GB') : '—';
    document.getElementById('fpTouch').textContent   = br.touchPoints || '0';
    document.getElementById('fpPlugins').textContent = br.pluginCount || '0';
    document.getElementById('fpScreen').textContent  =
        br.screen ? `${br.screen.width}×${br.screen.height}` : '—';

    // Score
    const sc  = r.score;
    const cls = scoreClass(sc);
    const msg = scoreMsg(sc);

    // Hero score
    const scoreHero = document.getElementById('scoreHero');
    scoreHero.classList.add('visible');
    const numEl  = document.getElementById('scoreNum');
    const fillEl = document.getElementById('scoreFill');
    numEl.textContent = sc + '%';
    numEl.className   = 'score-num ' + cls;
    document.getElementById('scoreVerdict').textContent = msg;
    setTimeout(() => {
        fillEl.style.width = sc + '%';
        fillEl.className = 'score-fill ' + cls;
    }, 150);

    // Risk pills
    const pills = document.getElementById('riskPills');
    pills.innerHTML = '';
    if (r.risks && r.risks.length) {
        r.risks.forEach(risk => {
            const p = document.createElement('span');
            p.className = 'risk-pill pill-red';
            p.textContent = risk.label;
            p.title = risk.detail || '';
            pills.appendChild(p);
        });
    }
    if (r.warnings && r.warnings.length) {
        r.warnings.forEach(w => {
            const p = document.createElement('span');
            p.className = 'risk-pill pill-amber';
            p.textContent = w.label;
            p.title = w.detail || '';
            pills.appendChild(p);
        });
    }
    if (!r.risks.length && !r.warnings.length) {
        const p = document.createElement('span');
        p.className = 'risk-pill pill-green';
        p.textContent = '✓ No issues found';
        pills.appendChild(p);
    }

    // Floating bar
    const wrap  = document.getElementById('scoreBarWrap');
    const pct   = document.getElementById('scPct');
    const scFill= document.getElementById('scFill');
    const scMsg = document.getElementById('scMsg');
    wrap.classList.add('visible');
    pct.textContent = sc + '%';
    pct.className   = 'sc-pct ' + cls;
    scMsg.textContent = msg;
    setTimeout(() => {
        scFill.style.width = sc + '%';
        scFill.className   = 'sc-fill ' + cls;
    }, 150);

    // Hide loading overlay
    setTimeout(() => {
        document.getElementById('loadingOverlay').classList.add('hidden');
    }, 300);
}

// ─── Main scan ───────────────────────────────────────────────────────────────
window.addEventListener('load', async () => {
    try {
        stepDone(1);
        // fp.js collectFingerprint() handles WebRTC step internally
        const fpData = await collectFingerprint();
        stepDone(2);
        stepDone(3);

        const res = await fetch('/api/process-scan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(fpData),
        });
        const data = await res.json();
        stepDone(4);

        if (data.success) {
            renderReport(data.report);
        } else {
            throw new Error('scan failed');
        }
    } catch (e) {
        console.error(e);
        document.getElementById('loadingOverlay').classList.add('hidden');
        document.getElementById('ipDisplay').textContent = 'Error';
        document.getElementById('locationLine').textContent = 'Scan failed — please refresh.';
    }
});
</script>
</body>
</html>
