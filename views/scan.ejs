        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        ans.style.maxHeight = ans.scrollHeight + 'px';
    }
}

// ─── DNS Leak Test ────────────────────────────────────────────────────────────
async function runDNSLeakTest() {
    const token = Math.random().toString(36).slice(2) + Date.now().toString(36);
    const PROBES = 6;

    // Fire multiple probe requests — each one hits the server from the browser's exit IP
    await Promise.all(Array.from({ length: PROBES }, (_, i) => 
        fetch(`/api/dns-probe/${token}-${i}`).catch(() => {})
    ));

    // Wait 500ms then collect results
    await new Promise(r => setTimeout(r, 500));

    try {
        const res  = await fetch(`/api/dns-results/${token.split('-')[0]}`);
        // Token prefix approach: collect any that start with our base token
        // Simpler: just poll all probes
        const data = await res.json();
        const ips  = data.ips || [];

        document.getElementById('dnsReqCount').textContent = PROBES;
        document.getElementById('dnsIpCount').textContent  = ips.length;
        document.getElementById('dnsIpList').textContent   = ips.length ? ips.join(' · ') : '—';

        const verdict = document.getElementById('dnsVerdict');
        const vText   = document.getElementById('dnsVerdictText');
        verdict.style.display = 'block';

        if (ips.length <= 1) {
            verdict.className = 'webrtc-result safe';
            vText.textContent = '✓ No DNS leak detected — all requests route through one exit IP';
            document.getElementById('dnsStatus').textContent = 'No leak';
        } else {
            verdict.className = 'webrtc-result leak';
            vText.textContent = `⚠ Possible DNS leak — ${ips.length} different exit IPs detected`;
            document.getElementById('dnsStatus').textContent = 'Leak detected';
        }
    } catch(e) {
        document.getElementById('dnsStatus').textContent = 'Test failed';
    }
}

// ─── Share Score Card ─────────────────────────────────────────────────────────
function shareScore() {
    const score  = parseInt(document.getElementById('scoreNum')?.textContent) || 0;
    const ip     = document.getElementById('ipDisplay')?.textContent || '';
    const loc    = document.getElementById('locationLine')?.textContent || '';
    const grade  = score >= 85 ? 'Private' : score >= 60 ? 'Some Risks' : 'At Risk';
    const color  = score >= 85 ? '#22d77a' : score >= 60 ? '#f5a623' : '#ff4f6a';

    const W = 600, H = 320;
    const c = document.createElement('canvas');
    c.width = W; c.height = H;
    const ctx = c.getContext('2d');

    // Background
    ctx.fillStyle = '#080b14';
    ctx.fillRect(0, 0, W, H);

    // Top accent line
    ctx.fillStyle = color;
    ctx.fillRect(0, 0, W, 3);

    // Border
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.strokeRect(0, 0, W, H);

    // Score circle
    ctx.beginPath();
    ctx.arc(110, 160, 72, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,255,255,0.04)';
    ctx.fill();
    ctx.strokeStyle = color;
    ctx.lineWidth = 3;
    ctx.stroke();

    ctx.fillStyle = color;
    ctx.font = 'bold 48px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(score + '%', 110, 175);
    
    ctx.font = '13px sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.fillText('PRIVACY SCORE', 110, 198);

    // Text info
    ctx.textAlign = 'left';
    ctx.fillStyle = '#f0f0f8';
    ctx.font = 'bold 26px sans-serif';
    ctx.fillText(grade, 210, 120);

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '14px monospace';
    ctx.fillText(ip, 210, 155);
    
    ctx.font = '13px sans-serif';
    ctx.fillText(loc, 210, 180);

    // Features line
    ctx.fillStyle = color;
    ctx.font = 'bold 12px monospace';
    ctx.fillText('whoer.live', 210, 220);
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.fillText(' — Free IP & VPN Test Tool', 298, 220);

    // Footer
    ctx.fillStyle = 'rgba(255,255,255,0.15)';
    ctx.font = '11px sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText('whoer.live', W - 20, H - 16);

    c.toBlob(blob => {
        if (navigator.share && navigator.canShare?.({ files: [new File([blob], 'privacy-score.png', { type: 'image/png' })] })) {
            navigator.share({
                title:  `My Privacy Score: ${score}% — ${grade}`,
                text:   `I checked my IP privacy on whoer.live and scored ${score}%. Check yours!`,
                url:    'https://www.whoer.live',
                files:  [new File([blob], 'privacy-score.png', { type: 'image/png' })],
            }).catch(() => downloadCard(blob));
        } else {
            downloadCard(blob);
        }
    }, 'image/png');
}

function downloadCard(blob) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'whoer-privacy-score.png';
    a.click();
}

