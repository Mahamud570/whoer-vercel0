    <!-- JSON-LD: WebApplication Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Whoer Live",
      "url": "https://whoer.live",
      "description": "Free IP address checker and privacy score tool",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "18450",
        "bestRating": "5"
      }
    }
    </script>
    <!-- JSON-LD: FAQ Schema (Google Rich Snippets) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is my IP address?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Your IP address is a unique number assigned to your internet connection by your ISP. Whoer Live detects it automatically and shows your country, city, ISP, and timezone — no signup needed."
          }
        },
        {
          "@type": "Question",
          "name": "How do I check if my VPN is working?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Visit whoer.live while connected to your VPN. If the IP address shown matches your VPN server location (not your real location), your VPN is working. We also check for WebRTC leaks that can reveal your real IP even when a VPN is active."
          }
        },
        {
          "@type": "Question",
          "name": "What is a WebRTC leak?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "WebRTC is a browser feature that enables video and voice calls. It can expose your real IP address even when you are using a VPN, because it bypasses VPN tunnels. Whoer Live tests your browser for this leak automatically."
          }
        },
        {
          "@type": "Question",
          "name": "Am I using a proxy or VPN?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Whoer Live checks your IP against known hosting, datacenter, and VPN provider IP ranges. If your connection routes through one of these, we flag it as a VPN or proxy and lower your privacy score."
          }
        },
        {
          "@type": "Question",
          "name": "How can I check my IP address in Bangladesh?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Simply visit whoer.live from any browser in Bangladesh. We detect your real IP assigned by your ISP (such as Grameenphone, BanglaLink, Robi, or AmberIT) and show your location instantly. No app or signup is required."
          }
        }
      ]
    }
    </script>
